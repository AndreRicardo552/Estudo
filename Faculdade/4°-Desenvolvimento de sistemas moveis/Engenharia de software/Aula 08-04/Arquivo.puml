@startuml DiagramaPOO
skinparam classAttributeIconSize 0

' --- Definição de Interfaces e Classes Abstratas ---
interface Autenticavel {
  +autenticar(): boolean
}

abstract class Pessoa {
  +nome: string
  +falar(): void
}

' --- Herança e Implementação ---
class Cliente {
  -id: int
  +realizarPedido(): Pedido
}

class Funcionario {
  -matricula: int
  +processarPedido(p: Pedido): void
}

class Usuario {
  -id: int
  -nome: string
  +login(): boolean
  +logout(): void
}

Pessoa <|-- Cliente
Pessoa <|-- Funcionario
Usuario ..|> Autenticavel

' --- Encapsulamento ---
class ContaBancaria {
  -saldo: float
  +depositar(valor: float): void
  +sacar(valor: float): boolean
}

' --- Composição e Agregação ---
class Motor
class Carro

Carro *-- Motor : "composição"
Carro o-- Usuario : "agregação"

' --- Associações e Multiplicidade ---
class Pedido {
  -numero: int
  -data: Date
  +finalizar(): void
}

class Produto {
  -codigo: int
  -descricao: string
  +calcularPreco(): float
}

enum StatusPedido {
  PENDENTE
  PAGO
  CANCELADO
}

Usuario "1" --> "0..*" Pedido
Pedido "1" --> "1..*" Produto
Pedido --> StatusPedido

@enduml